{
  "name": "logger",
  "version": "1.0.0",
  "private": true,
  "description": "World-class Discord logging bot with 70+ event types",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "pnpm db:push --accept-data-loss && turbo start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "pnpm --filter @logger/db generate",
    "db:push": "pnpm --filter @logger/db push",
    "db:migrate": "pnpm --filter @logger/db migrate",
    "db:studio": "pnpm --filter @logger/db studio",
    "deploy:commands": "pnpm --filter @logger/bot deploy:commands"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
